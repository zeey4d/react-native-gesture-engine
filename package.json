{
  "name": "@zeey4d/react-native-gesture-engine",
  "version": "1.0.0",
  "description": "A modular, production-ready 6-layer event-driven gesture engine for React Native",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "gesture",
    "gesture-engine",
    "gesture-handler",
    "reanimated",
    "shake",
    "edge-swipe",
    "pinch",
    "pan",
    "rotation",
    "sensors",
    "haptics",
    "accessibility"
  ],
  "author": "zeey4d",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeey4d/react-native-gesture-engine"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-gesture-handler": ">=2.20.0",
    "react-native-reanimated": ">=3.0.0",
    "expo-sensors": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "expo-haptics": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/react": "^18.2.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  }
}
